# === local data directories ===
SESSION_DIR=./data/sessions
MEMORY_DIR=./data/memory
LOG_DIR=./data/logs

# === agent permissions ===
RESTART_ALLOWLIST=Abdi,Dame
UNLOCK_ALLOWLIST=Abdi,Dame

# === windows/powershell ===
POWERSHELL_PATH=pwsh
DEFAULT_TIMEOUT_MS=30000

# === http transport ===
HTTP_PORT=3399
HTTP_HOST=127.0.0.1
HTTP_CORS_ORIGIN=http://localhost:3399
HTTP_API_KEY=replace_with_a_long_random_secret
HTTP_DEDUP_WINDOW_MS=60000
MCP_HTTP_BACKEND_URL=
MCP_HTTP_BACKEND_TIMEOUT_MS=10000

# === gateway / runtime ===
GATEWAY_URL=http://187.77.211.125:61299
GATEWAY_WS_URL=
GATEWAY_WS_ORIGIN=
GATEWAY_ENABLED=false
GATEWAY_CHAT_PATH=/api/chat/{agent}
GATEWAY_LOGIN_PATH=/login
GATEWAY_API_KEY=
GATEWAY_AUTH_HEADER=Authorization
LOG_LEVEL=info
NODE_ENV=development

# === github ===
GITHUB_TOKEN=your_github_personal_access_token_here

# === notion ===
NOTION_TOKEN=your_notion_integration_token_here

# === discord ===
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_API_BASE=https://discord.com/api/v10

# === telegram ===
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_API_BASE=https://api.telegram.org
ABDI_TELEGRAM_BOT_TOKEN=your_abdi_telegram_bot_token_here
AHMED_TELEGRAM_BOT_TOKEN=your_ahmed_telegram_bot_token_here
DAME_TELEGRAM_BOT_TOKEN=your_dame_telegram_bot_token_here
REX_TELEGRAM_BOT_TOKEN=your_rex_telegram_bot_token_here
PRIME_TELEGRAM_BOT_TOKEN=your_prime_telegram_bot_token_here
ATLAS_TELEGRAM_BOT_TOKEN=your_atlas_telegram_bot_token_here
AYUB_TELEGRAM_BOT_TOKEN=your_ayub_telegram_bot_token_here
SYGMA_TELEGRAM_BOT_TOKEN=your_sygma_telegram_bot_token_here

# === openrouter / per-agent runtime ===
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=your_shared_openai_api_key_here
ABDI_OPENROUTER_API_KEY=your_abdi_openrouter_api_key_here
AHMED_OPENROUTER_API_KEY=your_ahmed_openrouter_api_key_here
DAME_OPENROUTER_API_KEY=your_dame_openrouter_api_key_here
REX_OPENROUTER_API_KEY=your_rex_openrouter_api_key_here
PRIME_OPENROUTER_API_KEY=your_prime_openrouter_api_key_here
ATLAS_OPENROUTER_API_KEY=your_atlas_openrouter_api_key_here
AYUB_OPENROUTER_API_KEY=your_ayub_openrouter_api_key_here
SYGMA_OPENROUTER_API_KEY=your_sygma_openrouter_api_key_here
ABDI_OPENROUTER_MODEL_ID=openai/gpt-5.4
AHMED_OPENROUTER_MODEL_ID=openai/gpt-5.4-mini
DAME_OPENROUTER_MODEL_ID=openai/gpt-5.3-codex
REX_OPENROUTER_MODEL_ID=openai/gpt-5.4
PRIME_OPENROUTER_MODEL_ID=openai/gpt-5.4
ATLAS_OPENROUTER_MODEL_ID=openai/gpt-5.4
AYUB_OPENROUTER_MODEL_ID=openai/gpt-5.3-codex
SYGMA_OPENROUTER_MODEL_ID=openai/gpt-5.4-mini

# === google drive ===
GOOGLE_CLIENT_ID=your_google_oauth_client_id_here
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret_here
GOOGLE_REFRESH_TOKEN=your_google_refresh_token_here
GOOGLE_DRIVE_ACCESS_TOKEN=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
GOOGLE_DRIVE_DEFAULT_FOLDER_ID=

# === supabase ===
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
SUPABASE_ANON_KEY=
SUPABASE_SCHEMA=public

# === stripe ===
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_PRICE_ID_STARTER=price_starter_here
STRIPE_PRICE_ID_PRO=price_pro_here
STRIPE_PRICE_ID_ENTERPRISE=price_enterprise_here
STRIPE_CATALOG_JSON=[{"key":"starter","referenceId":"prod_or_price_id_here"}]
APP_BASE_URL=http://127.0.0.1:3399
BILLING_SUCCESS_URL=http://127.0.0.1:3399/billing/success?session_id={CHECKOUT_SESSION_ID}
BILLING_CANCEL_URL=http://127.0.0.1:3399/billing/cancel
BILLING_PORTAL_RETURN_URL=http://127.0.0.1:3399/billing

# === airtable ===
AIRTABLE_TOKEN=your_airtable_token_here
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# === n8n ===
N8N_BASE_URL=https://your-instance.n8n.cloud
N8N_API_KEY=your_n8n_api_key_here

# === elevenlabs voice ===
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID_ABDI=
ELEVENLABS_VOICE_ID_AHMED=
ELEVENLABS_VOICE_ID_DAME=
ELEVENLABS_VOICE_ID_REX=
ELEVENLABS_VOICE_ID_PRIME=
ELEVENLABS_VOICE_ID_ATLAS=
ELEVENLABS_VOICE_ID_AYUB=
ELEVENLABS_VOICE_ID_SYGMA=

# Memory system database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/c2_memory
MEMORY_DB_SSL=false

