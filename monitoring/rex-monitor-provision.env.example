# Copy this file to monitoring/rex-monitor-provision.env and fill credentials.
# Never commit real secrets.

UPTIME_KUMA_URL=http://localhost:3011
UPTIME_KUMA_PUBLIC_URL=http://localhost:3011
UPTIME_KUMA_USERNAME=admin
UPTIME_KUMA_PASSWORD=change_me
# Optional 2FA token if enabled for the account
UPTIME_KUMA_TOKEN=

# Comma-separated Uptime Kuma notification IDs.
# P0 and P1 only. Leave empty to skip notification attachment during provisioning.
REX_P0_NOTIFICATION_IDS=
REX_P1_NOTIFICATION_IDS=
