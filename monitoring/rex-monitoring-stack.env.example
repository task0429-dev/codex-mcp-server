# Copy to monitoring/rex-monitoring-stack.env and fill secrets.

# Internal URL (container-to-container)
UPTIME_KUMA_URL=http://uptime-kuma:3001
# External URL for generated docs/maps
UPTIME_KUMA_PUBLIC_URL=http://localhost:3011

UPTIME_KUMA_USERNAME=task
UPTIME_KUMA_PASSWORD=change_me
UPTIME_KUMA_TOKEN=

# Optional notification IDs
REX_P0_NOTIFICATION_IDS=
REX_P1_NOTIFICATION_IDS=

# Daemon intervals
REX_DAEMON_SYNC_INTERVAL_SEC=300
REX_DAEMON_HEARTBEAT_INTERVAL_SEC=30
REX_DAEMON_HEARTBEAT_MONITOR_NAME=HEARTBEAT - Rex Agent Loop
# Optional hard override
# REX_DAEMON_HEARTBEAT_PUSH_URL=http://uptime-kuma:3001/api/push/<token>
