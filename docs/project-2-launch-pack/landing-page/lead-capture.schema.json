{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Project2LeadCapture",
  "type": "object",
  "required": [
    "event",
    "submitted_at",
    "lead"
  ],
  "properties": {
    "event": { "type": "string", "enum": ["lead.captured"] },
    "submitted_at": { "type": "string", "format": "date-time" },
    "source": { "type": "string", "enum": ["landing_page"] },
    "cta_id": { "type": "string" },
    "lead": {
      "type": "object",
      "required": ["full_name", "email", "company", "team_size", "monthly_lead_goal", "consent_marketing"],
      "properties": {
        "full_name": { "type": "string", "minLength": 2 },
        "email": { "type": "string", "format": "email" },
        "company": { "type": "string", "minLength": 2 },
        "team_size": { "type": "string", "enum": ["1-10", "11-50", "51-200", "200+"] },
        "monthly_lead_goal": { "type": "integer", "minimum": 10 },
        "crm_in_use": { "type": "string" },
        "consent_marketing": { "type": "boolean", "const": true }
      }
    }
  }
}
